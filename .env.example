# ============================================================
# MiroFish Neo4j Fork — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# --- LLM Configuration (Required) ---
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# --- Zep Cloud (required by original MiroFish image) ---
# The original image checks for this at startup.
# Use a placeholder for now — Neo4j replacement is in progress.
ZEP_API_KEY=z_placeholder

# --- Neo4j (Local Graph Database) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish2026
